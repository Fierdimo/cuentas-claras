# Variables de entorno — App Cuentas
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el archivo .env al repositorio.

# ── Supabase (cliente móvil) ────────────────────────────────────────────────
# Estas variables son PÚBLICAS (van al bundle de la app).
# RLS está activo — un usuario solo puede ver sus propios datos.
EXPO_PUBLIC_SUPABASE_URL=https://REEMPLAZAR.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=REEMPLAZAR_CON_ANON_KEY

# ── Variables de entorno del servidor ──────────────────────────────────────
# Las siguientes variables NUNCA deben ir al bundle.
# Se configuran en Supabase con: supabase secrets set KEY=VALUE

# Supabase service role (solo Edge Functions)
# SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR

# Google OAuth (Gmail)
# GMAIL_CLIENT_ID=REEMPLAZAR
# GMAIL_CLIENT_SECRET=REEMPLAZAR        ← Solo Edge Functions
# GMAIL_WEBHOOK_SECRET=REEMPLAZAR       ← HMAC para validar webhooks Pub/Sub
# GMAIL_PUBSUB_SERVICE_ACCOUNT=gmail-api@system.gserviceaccount.com
# GMAIL_WEBHOOK_AUDIENCE=REEMPLAZAR     ← URL del Edge Function process-invoice

# Microsoft OAuth (Outlook)
# OUTLOOK_CLIENT_ID=REEMPLAZAR
# OUTLOOK_CLIENT_SECRET=REEMPLAZAR      ← Solo Edge Functions
